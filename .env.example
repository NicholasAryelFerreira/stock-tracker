# Copy this file to `.env` and fill in your key.
# `.env` is gitignored — never commit your real key.

OPENAI_API_KEY=

# Model for AI Insight & Daily Digest (structured text output).
# Verify the exact model ID against OpenAI's model list before deploying.
OPENAI_MODEL=gpt-5.4-nano-2026-03-17

# Model used when web search is enabled (the news summary).
# The web_search tool needs a reasoning-capable model — OpenAI recommends gpt-5.5.
# nano / minimal-reasoning models may not support web search well.
OPENAI_WEB_SEARCH_MODEL=gpt-5.5

# Web search result context size: low | medium | high (cost/latency vs. detail).
OPENAI_SEARCH_CONTEXT_SIZE=low
