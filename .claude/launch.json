{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8753", "--bind", "127.0.0.1", "--directory", "frontend"],
      "port": 8753
